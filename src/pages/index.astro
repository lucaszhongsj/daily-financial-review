---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const allReviews = await getCollection('reviews');
const publishedReviews = allReviews.filter(r => !r.data.draft);
const sortedReviews = publishedReviews.sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);
const latest = sortedReviews[0];
const totalCount = sortedReviews.length;

// Extract year-month for grouping
function getYearMonth(dateStr: string) {
  return dateStr.slice(0, 7);
}

const reviewsByMonth = new Map<string, typeof sortedReviews>();
for (const review of sortedReviews) {
  const ym = getYearMonth(review.data.date);
  if (!reviewsByMonth.has(ym)) reviewsByMonth.set(ym, []);
  reviewsByMonth.get(ym)!.push(review);
}
const sortedMonths = Array.from(reviewsByMonth.keys()).sort((a, b) => b.localeCompare(a));

// Calendar heatmap data
const sourceDir = path.join(process.cwd(), 'data', 'source');
const pnlByDate = new Map<string, number>();
const reviewIdByDate = new Map<string, string>();

for (const review of publishedReviews) {
  reviewIdByDate.set(review.data.date, review.id);
}

if (fs.existsSync(sourceDir)) {
  for (const file of fs.readdirSync(sourceDir)) {
    if (!file.endsWith('.json')) continue;
    const dateStr = file.replace('.json', '');
    try {
      const data = JSON.parse(fs.readFileSync(path.join(sourceDir, file), 'utf-8'));
      if (typeof data.total_pnl_pct === 'number') {
        pnlByDate.set(dateStr, data.total_pnl_pct);
      }
    } catch {}
  }
}

// Group by year
const years = Array.from(new Set(Array.from(pnlByDate.keys()).map(d => parseInt(d.slice(0, 4))))).sort((a, b) => b - a);

function getHeatColor(pnl: number | undefined): string {
  if (pnl === undefined) return 'transparent';
  const intensity = Math.min(1, Math.abs(pnl) / 5);
  if (pnl > 0) {
    // Red for up (A-share)
    return `rgba(239, 68, 68, ${0.15 + intensity * 0.7})`;
  } else {
    // Green for down
    return `rgba(34, 197, 94, ${0.15 + intensity * 0.7})`;
  }
}

---

<Layout title="每日理财复盘">
  {/* Hero */}
  <section class="mb-12 animate-fade-in-up">
    <h1 class="text-4xl sm:text-5xl font-black font-serif-zh text-gradient-gold mb-3 tracking-tight">
      每日理财复盘
    </h1>
    <p class="text-base sm:text-lg" style="color: var(--text-secondary);">
      记录投资思考，坚守交易纪律
    </p>
    {totalCount > 0 && (
      <div class="mt-4 flex items-center gap-4 text-sm" style="color: var(--text-muted);">
        <span>累计 <span class="font-mono-num font-semibold" style="color: var(--text-primary);">{totalCount}</span> 篇复盘</span>
        <span>·</span>
        <span>{sortedReviews[sortedReviews.length - 1]?.data.date} 至 {latest?.data.date}</span>
      </div>
    )}
  </section>

  {/* Latest review */}
  {latest && (
    <section class="mb-14 animate-fade-in-up animate-delay-1">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-1.5 h-5 rounded-full" style="background: var(--accent);"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
          最新复盘
        </h2>
      </div>

      <a
        href={`/review/${latest.id}`}
        class="group block relative overflow-hidden rounded-xl p-6 sm:p-8 transition-all duration-300"
        style="background: linear-gradient(145deg, var(--bg-card) 0%, var(--bg-elevated) 100%); border: 1px solid var(--border);"
      >
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 80% 20%, rgba(245, 158, 11, 0.06) 0%, transparent 60%);"></div>
        <div class="relative">
          <div class="flex items-baseline gap-3 mb-2">
            <span class="font-mono-num text-2xl font-bold" style="color: var(--accent);">
              {latest.data.date}
            </span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold font-serif-zh" style="color: var(--text-primary);">
            {latest.data.title}
          </h3>
          <div class="mt-4 flex items-center gap-2 text-sm" style="color: var(--text-muted);">
            <span>阅读全文</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      </a>
    </section>
  )}

  {/* Calendar heatmap — monthly mini grids */}
  {years.length > 0 && (
    <section class="mb-14 animate-fade-in-up animate-delay-2">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-5 rounded-full" style="background: var(--accent);"></div>
          <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
            盈亏日历
          </h2>
        </div>
        <div class="flex items-center gap-3 text-xs" style="color: var(--text-muted);">
          <span class="flex items-center gap-1">
            <span class="w-3 h-3 rounded-sm" style="background: rgba(239, 68, 68, 0.4);"></span> 盈
          </span>
          <span class="flex items-center gap-1">
            <span class="w-3 h-3 rounded-sm" style="background: rgba(34, 197, 94, 0.4);"></span> 亏
          </span>
        </div>
      </div>

      <div class="space-y-10">
        {years.map(year => {
          const isLeap = (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;
          const monthDays = [31, isLeap ? 29 : 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];

          return (
            <div>
              <h3 class="text-xs font-mono-num font-semibold uppercase tracking-wider mb-4" style="color: var(--text-muted);">
                {year}年
              </h3>

              <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3">
                {Array.from({length: 12}, (_, m) => {
                  const days = monthDays[m];
                  const firstDayOfMonth = new Date(year, m, 1).getDay();
                  const prefix = firstDayOfMonth; // empty cells before day 1
                  const totalCells = prefix + days;
                  const rows = Math.ceil(totalCells / 7);
                  const suffix = rows * 7 - totalCells; // empty cells after last day

                  return (
                    <div class="rounded-lg p-2.5 bg-card">
                      <div class="text-[10px] font-medium mb-1.5" style="color: var(--text-muted);">
                        {m + 1}月
                      </div>
                      <div class="grid grid-cols-7 gap-0.5">
                        {/* prefix */}
                        {Array.from({length: prefix}, (_, i) => (
                          <div class="w-3 h-3 rounded-sm" key={`p-${m}-${i}`} />
                        ))}
                        {/* days */}
                        {Array.from({length: days}, (_, d) => {
                          const day = d + 1;
                          const dateStr = `${year}-${String(m + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                          const pnl = pnlByDate.get(dateStr);
                          const reviewId = reviewIdByDate.get(dateStr);

                          const cell = (
                            <div
                              class="w-3 h-3 rounded-sm relative group cursor-pointer"
                              style={`background-color: ${getHeatColor(pnl)};`}
                              title={`${dateStr}${pnl !== undefined ? ` · 持仓盈亏 ${pnl >= 0 ? '+' : ''}${pnl.toFixed(2)}%` : ''}`}
                            >
                              {pnl !== undefined && (
                                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded text-[10px] whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10" style="background: var(--bg-elevated); color: var(--text-primary); border: 1px solid var(--border);"
                                >
                                  {dateStr} · {pnl >= 0 ? '+' : ''}{pnl.toFixed(2)}%
                                </div>
                              )}
                            </div>
                          );

                          if (reviewId) {
                            return <a href={`/review/${reviewId}`} class="contents" key={`d-${m}-${d}`}>{cell}</a>;
                          }
                          return <div class="contents" key={`d-${m}-${d}`}>{cell}</div>;
                        })}
                        {/* suffix */}
                        {Array.from({length: suffix}, (_, i) => (
                          <div class="w-3 h-3 rounded-sm" key={`s-${m}-${i}`} />
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  {/* Historical reviews by month */}
  {sortedMonths.length > 0 && (
    <section class="animate-fade-in-up animate-delay-3">
      <div class="flex items-center gap-2 mb-6">
        <div class="w-1.5 h-5 rounded-full" style="background: var(--text-muted);"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
          历史复盘
        </h2>
      </div>

      {sortedMonths.map((month, mi) => (
        <div class="mb-8">
          <h3 class="text-xs font-mono-num font-semibold uppercase tracking-wider mb-3 pl-1" style="color: var(--text-muted);">
            {month.replace('-', '年')}月
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {reviewsByMonth.get(month)!.map((review, ri) => (
              <a
                href={`/review/${review.id}`}
                class="group block rounded-lg p-4 transition-all duration-200 bg-card bg-card-hover"
                style={`animation: fade-in-up 0.4s ease-out ${(mi * 0.05 + ri * 0.03).toFixed(2)}s forwards; opacity: 0;`}
              >
                <div class="flex items-center justify-between gap-2">
                  <div class="min-w-0">
                    <div class="font-mono-num text-xs font-medium mb-1" style="color: var(--text-muted);">
                      {review.data.date}
                    </div>
                    <div class="text-sm font-medium truncate" style="color: var(--text-primary);">
                      {review.data.title}
                    </div>
                  </div>
                  <svg class="w-4 h-4 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-0.5 -translate-x-1" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  )}

  {sortedReviews.length === 0 && (
    <div class="text-center py-20" style="color: var(--text-muted);">
      <p class="text-lg">暂无已发布的复盘记录</p>
    </div>
  )}
</Layout>
