---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  const sorted = reviews
    .filter(r => !r.data.draft)
    .sort((a, b) => a.data.date.localeCompare(b.data.date));

  return sorted.map((review, i) => {
    const prev = sorted[i - 1] || null;
    const next = sorted[i + 1] || null;
    return {
      params: { id: review.id },
      props: { review, prev, next },
    };
  });
}

const { review, prev, next } = Astro.props;
const { Content } = await render(review);

// 读取 source 数据（指数 + 基金）
let sourceData: {
  date: string;
  indices: Array<{
    code: string;
    name: string;
    close: number;
    change_pct: number;
  }>;
  funds: Array<{
    code: string;
    name: string;
    nav: number;
    nav_date: string;
    change_pct: number;
    avg_cost?: number;
    pnl_pct?: number;
    shares?: number;
    is_qdii?: boolean;
  }>;
  total_pnl_pct?: number;
} | null = null;

try {
  const sourceFile = path.join(process.cwd(), 'data', 'source', `${review.data.date}.json`);
  if (fs.existsSync(sourceFile)) {
    sourceData = JSON.parse(fs.readFileSync(sourceFile, 'utf-8'));
  }
} catch {
  sourceData = null;
}

// 读取 analysis 数据
let analysisData: {
  today_focus?: string;
  market_comment?: string;
  position_analysis?: string;
  emotion_discipline?: string;
  tomorrow_plan?: string;
} | null = null;

try {
  const analysisFile = path.join(process.cwd(), 'data', 'analysis', `${review.data.date}.json`);
  if (fs.existsSync(analysisFile)) {
    analysisData = JSON.parse(fs.readFileSync(analysisFile, 'utf-8'));
  }
} catch {
  analysisData = null;
}

// 旧的 data/*.json 路径兼容（部分早期文件可能还在根目录）
if (!sourceData) {
  try {
    const legacyFile = path.join(process.cwd(), 'data', `${review.data.date}.json`);
    if (fs.existsSync(legacyFile)) {
      const legacy = JSON.parse(fs.readFileSync(legacyFile, 'utf-8'));
      sourceData = legacy;
    }
  } catch {
    sourceData = null;
  }
}

// 读取前后 30 天的数据用于趋势图
const sourceDir = path.join(process.cwd(), 'data', 'source');
const allSourceFiles = fs.existsSync(sourceDir)
  ? fs.readdirSync(sourceDir).filter(f => f.endsWith('.json')).sort()
  : [];

const currentIdx = allSourceFiles.findIndex(f => f === `${review.data.date}.json`);
const windowFiles = allSourceFiles.slice(
  Math.max(0, currentIdx - 15),
  Math.min(allSourceFiles.length, currentIdx + 16)
);

const trendData: { date: string; total_pnl_pct: number }[] = [];
const fundTrendData: Map<string, { date: string; pnl_pct: number }[]> = new Map();

for (const file of windowFiles) {
  try {
    const d = JSON.parse(fs.readFileSync(path.join(sourceDir, file), 'utf-8'));
    if (typeof d.total_pnl_pct === 'number') {
      trendData.push({ date: d.date, total_pnl_pct: d.total_pnl_pct });
    }
    for (const fund of d.funds || []) {
      if (fund.pnl_pct !== undefined && fund.pnl_pct !== null) {
        if (!fundTrendData.has(fund.name)) fundTrendData.set(fund.name, []);
        fundTrendData.get(fund.name)!.push({ date: d.date, pnl_pct: fund.pnl_pct });
      }
    }
  } catch {}
}

// SVG sparkline helper
function sparklinePath(data: { pnl_pct: number }[], w: number, h: number) {
  if (data.length < 2) return '';
  const values = data.map(d => d.pnl_pct);
  const min = Math.min(...values);
  const max = Math.max(...values);
  const range = max - min || 1;
  return data.map((d, i) => {
    const x = (i / (data.length - 1)) * w;
    const y = h - ((d.pnl_pct - min) / range) * h;
    return `${i === 0 ? 'M' : 'L'}${x},${y}`;
  }).join(' ');
}

// SVG trend chart helper
function trendChartData(data: { date: string; total_pnl_pct: number }[], w: number, h: number, pad: number) {
  if (data.length < 2) return null;
  const values = data.map(d => d.total_pnl_pct);
  const min = Math.min(...values);
  const max = Math.max(...values);
  const range = max - min || 1;
  const cw = w - pad * 2;
  const ch = h - pad * 2;

  const points = data.map((d, i) => {
    const x = pad + (i / (data.length - 1)) * cw;
    const y = pad + ch - ((d.total_pnl_pct - min) / range) * ch;
    return `${x},${y}`;
  }).join(' ');

  const zeroY = pad + ch - ((0 - min) / range) * ch;
  return { points, zeroY, min, max, w, h, pad, cw, ch };
}

const overallTrend = trendChartData(trendData, 700, 180, 30);

// 辅助函数
function formatChange(val: number | null | undefined) {
  if (val === null || val === undefined) return '-';
  const sign = val >= 0 ? '+' : '';
  return `${sign}${val.toFixed(2)}%`;
}

function changeClass(val: number | null | undefined) {
  if (val === null || val === undefined) return '';
  return val >= 0 ? 'text-up' : 'text-down';
}

function changeBgClass(val: number | null | undefined) {
  if (val === null || val === undefined) return '';
  return val >= 0 ? 'bg-up' : 'bg-down';
}

function borderAccentClass(val: number | null | undefined) {
  if (val === null || val === undefined) return '';
  return val >= 0 ? 'border-l-[var(--up)]' : 'border-l-[var(--down)]';
}

function pnlBarStyle(val: number | null | undefined) {
  if (val === null || val === undefined) return '';
  // Map -50% to +50% range to 0-100% width, clamped
  const pct = Math.max(0, Math.min(100, ((val + 50) / 100) * 100));
  return `width: ${pct}%;`;
}

const sections = [
  { key: 'today_focus', label: '今日关注', icon: '●' },
  { key: 'market_comment', label: '大盘点评', icon: '◆' },
  { key: 'position_analysis', label: '持仓分析', icon: '■' },
  { key: 'emotion_discipline', label: '情绪与纪律', icon: '▲' },
  { key: 'tomorrow_plan', label: '明日计划', icon: '◈' },
] as const;
---

<Layout title={review.data.title}>
  {/* Back link */}
  <a
    href="/"
    class="inline-flex items-center gap-1.5 text-sm mb-6 transition-colors hover:text-[var(--text-primary)]"
    style="color: var(--text-muted);"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    返回首页
  </a>

  {/* Title header */}
  <header class="mb-8 animate-fade-in-up">
    <div class="flex items-baseline gap-3 mb-2 flex-wrap">
      <span class="font-mono-num text-2xl sm:text-3xl font-bold" style="color: var(--accent);">
        {review.data.date}
      </span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold font-serif-zh" style="color: var(--text-primary);">
      {review.data.title}
    </h1>

    {sourceData?.total_pnl_pct !== undefined && (
      <div class="mt-4 inline-flex items-center gap-3 rounded-lg px-4 py-2 bg-card">
        <span class="text-sm" style="color: var(--text-secondary);">整体持仓盈亏</span>
        <span class={`font-mono-num text-xl font-bold ${changeClass(sourceData.total_pnl_pct)}`}>
          {formatChange(sourceData.total_pnl_pct)}
        </span>
      </div>
    )}
  </header>

  {/* Indices cards */}
  {sourceData?.indices && sourceData.indices.length > 0 && (
    <section class="mb-8 animate-fade-in-up animate-delay-1">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-1.5 h-5 rounded-full" style="background: var(--accent);"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
          大盘指数
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {sourceData.indices.map((idx, i) => (
          <div
            class={`relative overflow-hidden rounded-lg p-4 bg-card border-l-4 ${borderAccentClass(idx.change_pct)}`}
            style={`animation: fade-in-up 0.4s ease-out ${i * 0.05}s forwards; opacity: 0;`}
          >
            <div class="text-xs mb-1 truncate" style="color: var(--text-muted);">{idx.name}</div>
            <div class="font-mono-num text-xl font-bold mb-1" style="color: var(--text-primary);">
              {idx.close?.toFixed(2) ?? '-'}
            </div>
            <div class={`inline-block rounded px-2 py-0.5 text-xs font-mono-num font-semibold ${changeBgClass(idx.change_pct)} ${changeClass(idx.change_pct)}`}>
              {formatChange(idx.change_pct)}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* Fund cards */}
  {sourceData?.funds && sourceData.funds.length > 0 && (
    <section class="mb-8 animate-fade-in-up animate-delay-2">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-1.5 h-5 rounded-full" style="background: var(--accent);"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
          基金持仓
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {sourceData.funds.map((fund, i) => (
          <div
            class="relative overflow-hidden rounded-lg p-4 bg-card"
            style={`animation: fade-in-up 0.4s ease-out ${i * 0.05}s forwards; opacity: 0;`}
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <div class="min-w-0">
                <div class="text-sm font-medium truncate" style="color: var(--text-primary);">
                  {fund.name}
                </div>
                {fund.is_qdii && (
                  <span class="inline-block mt-1 text-[10px] px-1.5 py-0.5 rounded font-mono-num" style="background: var(--accent-bg); color: var(--accent);">
                    QDII
                  </span>
                )}
              </div>
              <div class={`text-sm font-mono-num font-bold ${changeClass(fund.change_pct)}`}>
                {formatChange(fund.change_pct)}
              </div>
            </div>

            <div class="flex items-end justify-between gap-4">
              <div>
                <div class="text-xs mb-0.5" style="color: var(--text-muted);">净值</div>
                <div class="font-mono-num text-lg font-bold" style="color: var(--text-primary);">
                  {fund.nav?.toFixed(4) ?? '-'}
                </div>
              </div>
              {fund.pnl_pct !== undefined && fund.pnl_pct !== null && (
                <div class="text-right">
                  <div class="text-xs mb-0.5" style="color: var(--text-muted);">持仓盈亏</div>
                  <div class={`font-mono-num text-lg font-bold ${changeClass(fund.pnl_pct)}`}>
                    {formatChange(fund.pnl_pct)}
                  </div>
                </div>
              )}
            </div>

            {/* Sparkline */}
            {(() => {
              const trend = fundTrendData.get(fund.name);
              if (!trend || trend.length < 2) return null;
              const d = sparklinePath(trend, 200, 32);
              return (
                <div class="mt-3">
                  <svg viewBox="0 0 200 32" class="w-full h-8" preserveAspectRatio="none">
                    <path d={d} fill="none" stroke={fund.pnl_pct! >= 0 ? 'var(--up)' : 'var(--down)'} stroke-width="1.5" stroke-linejoin="round" opacity="0.6" />
                  </svg>
                </div>
              );
            })()}

            {/* PnL progress bar */}
            {fund.pnl_pct !== undefined && fund.pnl_pct !== null && (
              <div class="mt-2">
                <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--bg-elevated);">
                  <div
                    class={`h-full rounded-full transition-all duration-700 ${fund.pnl_pct >= 0 ? 'bg-[var(--up)]' : 'bg-[var(--down)]'}`}
                    style={pnlBarStyle(fund.pnl_pct)}
                  />
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Overall trend chart */}
      {overallTrend && (
        <div class="mt-4 rounded-lg p-4 bg-card">
          <div class="text-xs mb-2" style="color: var(--text-muted);">近 {trendData.length} 日持仓盈亏趋势</div>
          <svg viewBox={`0 0 ${overallTrend.w} ${overallTrend.h}`} class="w-full" style="min-width: 400px;">
            {/* Zero line */}
            <line x1={overallTrend.pad} y1={overallTrend.zeroY} x2={overallTrend.w - overallTrend.pad} y2={overallTrend.zeroY}
              stroke="var(--text-muted)" stroke-width="0.5" stroke-dasharray="3,3" />
            {/* Area */}
            <polygon
              points={`${overallTrend.pad},${overallTrend.zeroY} ${overallTrend.points} ${overallTrend.w - overallTrend.pad},${overallTrend.zeroY}`}
              fill="rgba(245, 158, 11, 0.06)"
            />
            {/* Line */}
            <polyline points={overallTrend.points} fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linejoin="round" />
          </svg>
        </div>
      )}
    </section>
  )}

  {/* Analysis cards */}
  {analysisData && (
    <section class="mb-8 animate-fade-in-up animate-delay-3">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-1.5 h-5 rounded-full" style="background: var(--text-muted);"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
          复盘分析
        </h2>
      </div>
      <div class="space-y-3">
        {sections.map((sec, i) => {
          const content = analysisData?.[sec.key];
          if (!content) return null;
          return (
            <div
              class="rounded-lg p-4 sm:p-5 bg-card"
              style={`animation: fade-in-up 0.4s ease-out ${i * 0.05}s forwards; opacity: 0;`}
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs" style="color: var(--accent);">{sec.icon}</span>
                <h3 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--text-muted);">
                  {sec.label}
                </h3>
              </div>
              <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
                {content}
              </p>
            </div>
          );
        })}
      </div>
    </section>
  )}

  {/* Markdown content */}
  <article class="animate-fade-in-up animate-delay-4">
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>

  {/* Timeline navigation */}
  <nav class="mt-10 flex items-center justify-between gap-4 animate-fade-in-up animate-delay-5">
    {prev ? (
      <a
        href={`/review/${prev.id}`}
        class="group flex items-center gap-2 rounded-lg px-4 py-3 bg-card bg-card-hover transition-all flex-1"
        data-nav="prev"
      >
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <div class="min-w-0">
          <div class="text-[10px] uppercase tracking-wider" style="color: var(--text-muted);">上一日</div>
          <div class="text-sm font-mono-num font-medium truncate" style="color: var(--text-primary);">{prev.data.date}</div>
        </div>
      </a>
    ) : (
      <div class="flex-1" />
    )}

    {next ? (
      <a
        href={`/review/${next.id}`}
        class="group flex items-center gap-2 rounded-lg px-4 py-3 bg-card bg-card-hover transition-all flex-1 justify-end text-right"
        data-nav="next"
      >
        <div class="min-w-0">
          <div class="text-[10px] uppercase tracking-wider" style="color: var(--text-muted);">下一日</div>
          <div class="text-sm font-mono-num font-medium truncate" style="color: var(--text-primary);">{next.data.date}</div>
        </div>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    ) : (
      <div class="flex-1" />
    )}
  </nav>

  <script>
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        const prev = document.querySelector('a[data-nav="prev"]') as HTMLAnchorElement | null;
        if (prev) prev.click();
      } else if (e.key === 'ArrowRight') {
        const next = document.querySelector('a[data-nav="next"]') as HTMLAnchorElement | null;
        if (next) next.click();
      }
    });
  </script>
</Layout>
