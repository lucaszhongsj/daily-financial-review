---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '每日理财复盘 — 记录投资思考与纪律' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f19" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen antialiased">
    {/* Navigation */}
    <nav class="sticky top-0 z-50 border-b border-subtle" style="background-color: rgba(11, 15, 25, 0.85); backdrop-filter: blur(12px);">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 group">
            <span class="text-lg font-bold text-gradient-gold font-serif-zh tracking-tight">每日理财复盘</span>
          </a>
          <a
            href="/"
            class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors"
          >
            首页
          </a>
        </div>
      </div>
    </nav>

    {/* Main content */}
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <slot />
    </main>

    {/* Footer */}
    <footer class="border-t border-subtle mt-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-xs text-center" style="color: var(--text-muted);">
          每日理财复盘 · 记录投资思考与纪律
        </p>
      </div>
    </footer>
  </body>
</html>
